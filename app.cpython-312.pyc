<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>EquiSwap — Exchange Skills, Build Together</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<style>
:root{--sage:#7C9A7E;--sage-light:#A8C5AA;--sage-dark:#4A6B4C;--teal:#1A4A4A;--teal-mid:#2D6B6B;--teal-light:#3D8B8B;--white:#F8F9F6;--mist:#EDF0EC;--gray:#9BA89C;--dark:#0F1F1F;}
*{margin:0;padding:0;box-sizing:border-box;}html{scroll-behavior:smooth;}
body{font-family:'DM Sans',sans-serif;background:var(--white);color:var(--dark);overflow-x:hidden;}
#bg-canvas{position:fixed;top:0;left:0;width:100%;height:100%;z-index:0;pointer-events:none;opacity:0.5;}
nav{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;align-items:center;justify-content:space-between;padding:20px 60px;background:rgba(248,249,246,0.88);backdrop-filter:blur(20px);border-bottom:1px solid rgba(124,154,126,0.12);transition:all 0.3s;}
nav.scrolled{padding:14px 60px;box-shadow:0 4px 30px rgba(26,74,74,0.08);}
.logo{font-family:'Cormorant Garamond',serif;font-size:26px;font-weight:600;color:var(--teal);text-decoration:none;letter-spacing:-0.5px;}
.logo span{color:var(--sage);}
.nav-links{display:flex;align-items:center;gap:36px;list-style:none;}
.nav-links a{text-decoration:none;color:var(--teal);font-size:14px;font-weight:500;transition:color 0.2s;}
.nav-links a:hover{color:var(--sage-dark);}
.nav-acts{display:flex;align-items:center;gap:12px;}
.btn-ghost{padding:9px 22px;border:1.5px solid var(--sage);background:transparent;color:var(--teal);border-radius:50px;font-size:14px;font-weight:500;font-family:'DM Sans',sans-serif;cursor:pointer;text-decoration:none;transition:all 0.25s;}
.btn-ghost:hover{background:var(--sage);color:white;transform:translateY(-1px);}
.btn-primary{padding:9px 24px;background:var(--teal);color:white;border:none;border-radius:50px;font-size:14px;font-weight:500;font-family:'DM Sans',sans-serif;cursor:pointer;text-decoration:none;transition:all 0.25s;box-shadow:0 4px 15px rgba(26,74,74,0.25);}
.btn-primary:hover{background:var(--teal-mid);transform:translateY(-1px);box-shadow:0 6px 20px rgba(26,74,74,0.35);}
/* HERO */
.hero{position:relative;z-index:1;min-height:100vh;display:flex;align-items:center;justify-content:center;text-align:center;padding:120px 20px 80px;}
.hero-inner{max-width:820px;}
.hero-badge{display:inline-flex;align-items:center;gap:8px;background:rgba(124,154,126,0.12);border:1px solid rgba(124,154,126,0.3);padding:6px 16px;border-radius:50px;font-size:12px;font-weight:500;color:var(--sage-dark);margin-bottom:36px;letter-spacing:0.5px;text-transform:uppercase;}
.badge-dot{width:6px;height:6px;background:var(--sage);border-radius:50%;animation:pulse 2s ease infinite;}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1);}50%{opacity:0.5;transform:scale(1.3);}}
h1{font-family:'Cormorant Garamond',serif;font-size:clamp(52px,8vw,88px);font-weight:300;line-height:1.05;color:var(--teal);letter-spacing:-2px;margin-bottom:28px;}
h1 em{font-style:italic;color:var(--sage);}
.hero-sub{font-size:18px;color:var(--gray);line-height:1.7;max-width:580px;margin:0 auto 48px;font-weight:300;}
.hero-acts{display:flex;gap:14px;justify-content:center;flex-wrap:wrap;}
.btn-hero{padding:16px 40px;border-radius:50px;font-size:15px;font-weight:500;font-family:'DM Sans',sans-serif;cursor:pointer;text-decoration:none;transition:all 0.3s;display:inline-block;}
.btn-hero-primary{background:var(--teal);color:white;border:none;box-shadow:0 8px 30px rgba(26,74,74,0.3);}
.btn-hero-primary:hover{transform:translateY(-2px);box-shadow:0 12px 40px rgba(26,74,74,0.4);}
.btn-hero-ghost{background:transparent;color:var(--teal);border:1.5px solid rgba(26,74,74,0.25);}
.btn-hero-ghost:hover{border-color:var(--sage);color:var(--sage-dark);transform:translateY(-2px);}
.hero-stats{display:flex;gap:48px;justify-content:center;margin-top:64px;padding-top:48px;border-top:1px solid rgba(124,154,126,0.2);flex-wrap:wrap;}
.stat-item{text-align:center;}
.stat-num{font-family:'Cormorant Garamond',serif;font-size:44px;font-weight:600;color:var(--teal);line-height:1;}
.stat-lbl{font-size:12px;color:var(--gray);margin-top:4px;letter-spacing:0.5px;text-transform:uppercase;}
/* SECTIONS */
section{position:relative;z-index:1;}
.sec-pad{padding:100px 60px;}
.sec-lbl{font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(--sage);font-weight:600;margin-bottom:16px;}
.sec-ttl{font-family:'Cormorant Garamond',serif;font-size:clamp(36px,5vw,54px);font-weight:300;color:var(--teal);line-height:1.15;letter-spacing:-1px;}
.sec-ttl em{font-style:italic;color:var(--sage);}
/* STEPS */
.steps{background:var(--mist);}
.steps-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:30px;margin-top:64px;}
.step-card{background:rgba(255,255,255,0.75);backdrop-filter:blur(20px);border-radius:24px;padding:40px 36px;border:1px solid rgba(124,154,126,0.15);box-shadow:0 4px 30px rgba(26,74,74,0.05);transition:all 0.35s;position:relative;overflow:hidden;}
.step-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--sage),var(--teal-light));transform:scaleX(0);transition:transform 0.35s;transform-origin:left;}
.step-card:hover{transform:translateY(-6px);box-shadow:0 20px 60px rgba(26,74,74,0.12);}
.step-card:hover::before{transform:scaleX(1);}
.step-num{font-family:'Cormorant Garamond',serif;font-size:72px;font-weight:300;color:rgba(124,154,126,0.2);line-height:1;margin-bottom:16px;}
.step-ico{width:48px;height:48px;background:linear-gradient(135deg,var(--sage-light),var(--teal-light));border-radius:14px;display:flex;align-items:center;justify-content:center;margin-bottom:18px;font-size:22px;}
.step-ttl{font-size:20px;font-weight:600;color:var(--teal);margin-bottom:12px;}
.step-desc{font-size:14px;color:var(--gray);line-height:1.7;font-weight:300;}
/* BENEFITS */
.bene-grid{display:grid;grid-template-columns:1fr 1fr;gap:30px;margin-top:64px;}
.bene-card{background:rgba(255,255,255,0.8);border-radius:28px;padding:48px;border:1px solid rgba(124,154,126,0.15);box-shadow:0 4px 30px rgba(26,74,74,0.04);transition:all 0.35s;}
.bene-card:hover{transform:translateY(-4px);box-shadow:0 16px 50px rgba(26,74,74,0.1);}
.bene-tag{display:inline-block;padding:4px 14px;border-radius:50px;font-size:11px;font-weight:600;letter-spacing:0.8px;text-transform:uppercase;margin-bottom:24px;}
.tag-f{background:rgba(26,74,74,0.1);color:var(--teal);}
.tag-s{background:rgba(124,154,126,0.15);color:var(--sage-dark);}
.bene-ttl{font-family:'Cormorant Garamond',serif;font-size:32px;font-weight:400;color:var(--teal);margin-bottom:20px;}
.bene-list{list-style:none;display:flex;flex-direction:column;gap:12px;}
.bene-list li{display:flex;align-items:flex-start;gap:12px;font-size:14px;color:var(--gray);line-height:1.6;font-weight:300;}
.bene-list li::before{content:'✦';color:var(--sage);font-size:10px;margin-top:4px;flex-shrink:0;}
/* TESTIMONIALS */
.testi{background:var(--teal);}
.testi .sec-lbl{color:var(--sage-light);}
.testi .sec-ttl{color:white;}
.testi .sec-ttl em{color:var(--sage-light);}
.testi-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-top:64px;}
.testi-card{background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.12);border-radius:24px;padding:36px;transition:all 0.3s;}
.testi-card:hover{background:rgba(255,255,255,0.1);transform:translateY(-4px);}
.testi-stars{color:var(--sage-light);font-size:14px;margin-bottom:18px;letter-spacing:2px;}
.testi-txt{font-family:'Cormorant Garamond',serif;font-size:18px;font-style:italic;color:rgba(255,255,255,0.85);line-height:1.7;margin-bottom:22px;}
.testi-author{display:flex;align-items:center;gap:14px;}
.t-av{width:44px;height:44px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:16px;font-weight:600;color:white;font-family:'Cormorant Garamond',serif;}
.t-name{font-size:14px;font-weight:600;color:white;}
.t-role{font-size:12px;color:rgba(255,255,255,0.5);margin-top:2px;}
/* CTA */
.cta{background:linear-gradient(135deg,var(--mist) 0%,rgba(124,154,126,0.1) 100%);text-align:center;}
.cta-inner{max-width:680px;margin:0 auto;}
.cta-desc{font-size:17px;color:var(--gray);line-height:1.7;margin-bottom:48px;font-weight:300;margin-top:20px;}
.cta-btns{display:flex;gap:14px;justify-content:center;flex-wrap:wrap;}
/* FOOTER */
footer{background:var(--dark);color:rgba(255,255,255,0.5);padding:48px 60px;display:flex;align-items:center;justify-content:space-between;position:relative;z-index:1;}
.f-logo{font-family:'Cormorant Garamond',serif;font-size:22px;font-weight:600;color:white;}
.f-logo span{color:var(--sage);}
.f-links{display:flex;gap:28px;}
.f-links a{color:rgba(255,255,255,0.5);text-decoration:none;font-size:13px;transition:color 0.2s;}
.f-links a:hover{color:var(--sage-light);}
/* ANIMATIONS */
.fade-in{opacity:0;transform:translateY(30px);transition:opacity 0.7s,transform 0.7s;}
.fade-in.vis{opacity:1;transform:translateY(0);}
.fd1{transition-delay:0.1s;}.fd2{transition-delay:0.2s;}.fd3{transition-delay:0.3s;}
/* REAL STATS HIGHLIGHT */
.stat-num.zero{color:var(--gray);}
@media(max-width:900px){nav{padding:16px 24px;}.nav-links{display:none;}.sec-pad{padding:70px 24px;}.steps-grid,.bene-grid,.testi-grid{grid-template-columns:1fr;}footer{flex-direction:column;gap:20px;text-align:center;}}
</style>
</head>
<body>
<canvas id="bg-canvas"></canvas>

<nav id="navbar">
  <a href="/" class="logo">Equi<span>Swap</span></a>
  <ul class="nav-links">
    <li><a href="#how-it-works">How It Works</a></li>
    <li><a href="#benefits">Benefits</a></li>
    <li><a href="#testimonials">Stories</a></li>
  </ul>
  <div class="nav-acts">
    <a href="/login" class="btn-ghost">Log In</a>
    <a href="/signup" class="btn-primary">Get Started</a>
  </div>
</nav>

<section class="hero">
  <div class="hero-inner">
    <div class="hero-badge">
      <div class="badge-dot"></div>
      Live Platform · Join Today
    </div>
    <h1>Where <em>founders</em><br>meet brilliant<br>specialists</h1>
    <p class="hero-sub">Post what your startup needs. Discover specialists who deliver. Build extraordinary products together through the power of skill exchange.</p>
    <div class="hero-acts">
      <a href="/signup?role=founder" class="btn-hero btn-hero-primary">I'm a Founder →</a>
      <a href="/signup?role=specialist" class="btn-hero btn-hero-ghost">I'm a Specialist</a>
    </div>
    <div class="hero-stats">
      <div class="stat-item">
        <div class="stat-num {{ 'zero' if stats.total_users == 0 else '' }}" data-real="{{ stats.total_users }}">{{ stats.total_users }}</div>
        <div class="stat-lbl">Members</div>
      </div>
      <div class="stat-item">
        <div class="stat-num {{ 'zero' if stats.total_posts == 0 else '' }}" data-real="{{ stats.total_posts }}">{{ stats.total_posts }}</div>
        <div class="stat-lbl">Posts Published</div>
      </div>
      <div class="stat-item">
        <div class="stat-num {{ 'zero' if stats.total_applications == 0 else '' }}" data-real="{{ stats.total_applications }}">{{ stats.total_applications }}</div>
        <div class="stat-lbl">Applications Sent</div>
      </div>
      <div class="stat-item">
        <div class="stat-num {{ 'zero' if stats.accepted_applications == 0 else '' }}" data-real="{{ stats.accepted_applications }}">{{ stats.accepted_applications }}</div>
        <div class="stat-lbl">Connections Made</div>
      </div>
    </div>
  </div>
</section>

<section class="steps sec-pad" id="how-it-works">
  <div class="sec-lbl fade-in">Process</div>
  <h2 class="sec-ttl fade-in">Three steps to your <em>perfect match</em></h2>
  <div class="steps-grid">
    <div class="step-card fade-in fd1"><div class="step-num">01</div><div class="step-ico">🚀</div><div class="step-ttl">Founders Post a Need</div><p class="step-desc">Describe exactly what your startup needs — design, development, marketing, or anything else. Set your timeline and required skills.</p></div>
    <div class="step-card fade-in fd2"><div class="step-num">02</div><div class="step-ico">✦</div><div class="step-ttl">Specialists Apply</div><p class="step-desc">Talented specialists browse opportunities and apply with their portfolio, CV, and a personalized pitch. Quality applications matched by skill.</p></div>
    <div class="step-card fade-in fd3"><div class="step-num">03</div><div class="step-ico">🤝</div><div class="step-ttl">Connect & Collaborate</div><p class="step-desc">Review applicants, use our AI assistant to evaluate fit, message directly, and build something remarkable together.</p></div>
  </div>
</section>

<section class="sec-pad" id="benefits" style="background:var(--white);">
  <div class="sec-lbl fade-in">Who it's for</div>
  <h2 class="sec-ttl fade-in">Built for two sides of <em>every great product</em></h2>
  <div class="bene-grid">
    <div class="bene-card fade-in fd1">
      <span class="bene-tag tag-f">For Founders</span>
      <div class="bene-ttl">Launch faster with the right people</div>
      <ul class="bene-list">
        <li>Post service needs in minutes with full requirements</li>
        <li>Receive applications from motivated specialists</li>
        <li>Review portfolios, CVs, and personalized pitches</li>
        <li>Use the AI assistant to evaluate applicant fit</li>
        <li>Accept, message, and collaborate in one place</li>
        <li>Track all projects from a beautiful dashboard</li>
      </ul>
    </div>
    <div class="bene-card fade-in fd2">
      <span class="bene-tag tag-s">For Specialists</span>
      <div class="bene-ttl">Find work that matches your craft</div>
      <ul class="bene-list">
        <li>Discover exciting startup projects for your skills</li>
        <li>Apply with your CV, portfolio, and pitch message</li>
        <li>Ask the AI if a founder is worth working with</li>
        <li>Connect directly with serious, motivated founders</li>
        <li>Track all applications in a clean dashboard</li>
        <li>Grow your reputation in a curated network</li>
      </ul>
    </div>
  </div>
</section>

<section class="testi sec-pad" id="testimonials">
  <div class="sec-lbl fade-in">Stories</div>
  <h2 class="sec-ttl fade-in">What our members <em>are saying</em></h2>
  <div class="testi-grid">
    <div class="testi-card fade-in fd1"><div class="testi-stars">★★★★★</div><p class="testi-txt">"The AI assistant helped me immediately understand which applicant was the best fit. It analyzed their skills against my post in seconds."</p><div class="testi-author"><div class="t-av" style="background:linear-gradient(135deg,#2D6B6B,#3D8B8B);">S</div><div><div class="t-name">Sarah Chen</div><div class="t-role">Founder, NovaPay</div></div></div></div>
    <div class="testi-card fade-in fd2"><div class="testi-stars">★★★★★</div><p class="testi-txt">"I asked the AI 'is this founder serious?' and it gave me a detailed breakdown of their post quality, deadline realism, and what to expect. Invaluable."</p><div class="testi-author"><div class="t-av" style="background:linear-gradient(135deg,#7C9A7E,#4A6B4C);">M</div><div><div class="t-name">Marcus Osei</div><div class="t-role">Senior Developer</div></div></div></div>
    <div class="testi-card fade-in fd3"><div class="testi-stars">★★★★★</div><p class="testi-txt">"The platform feels premium and the AI chat is genuinely useful. I found three great specialists and the whole process was smooth from start to finish."</p><div class="testi-author"><div class="t-av" style="background:linear-gradient(135deg,#4A6B4C,#7C9A7E);">L</div><div><div class="t-name">Layla Hassan</div><div class="t-role">Founder, Bloom Studio</div></div></div></div>
  </div>
</section>

<section class="cta sec-pad">
  <div class="cta-inner">
    <div class="sec-lbl fade-in">Join EquiSwap</div>
    <h2 class="sec-ttl fade-in">Ready to build <em>something great?</em></h2>
    <p class="cta-desc fade-in">Join founders and specialists already building the future together. It's free to get started.</p>
    <div class="cta-btns fade-in">
      <a href="/signup?role=founder" class="btn-hero btn-hero-primary">Join as Founder</a>
      <a href="/signup?role=specialist" class="btn-hero btn-hero-ghost">Join as Specialist</a>
    </div>
  </div>
</section>

<footer>
  <div class="f-logo">Equi<span>Swap</span></div>
  <div style="font-size:13px;">© 2026 EquiSwap. All rights reserved.</div>
  <div class="f-links"><a href="#">Privacy</a><a href="#">Terms</a><a href="/login">Login</a></div>
</footer>

<script>
// THREE.JS BACKGROUND
const scene=new THREE.Scene(),camera=new THREE.PerspectiveCamera(60,window.innerWidth/window.innerHeight,.1,1000),renderer=new THREE.WebGLRenderer({canvas:document.getElementById('bg-canvas'),alpha:true,antialias:true});
renderer.setSize(window.innerWidth,window.innerHeight);renderer.setPixelRatio(Math.min(devicePixelRatio,2));camera.position.z=30;
const geos=[new THREE.TorusGeometry(2,.4,16,60),new THREE.IcosahedronGeometry(1.5,1),new THREE.OctahedronGeometry(1.8),new THREE.TorusGeometry(1.5,.3,12,40),new THREE.IcosahedronGeometry(2,0)];
const mats=[new THREE.MeshBasicMaterial({color:0x7C9A7E,wireframe:true,transparent:true,opacity:.28}),new THREE.MeshBasicMaterial({color:0x1A4A4A,wireframe:true,transparent:true,opacity:.18}),new THREE.MeshBasicMaterial({color:0x3D8B8B,wireframe:true,transparent:true,opacity:.22})];
const shapes=[];
for(let i=0;i<9;i++){const g=geos[i%geos.length],m=mats[i%mats.length].clone(),mesh=new THREE.Mesh(g,m);mesh.position.set((Math.random()-.5)*65,(Math.random()-.5)*45,(Math.random()-.5)*25);mesh.rotation.set(Math.random()*Math.PI*2,Math.random()*Math.PI*2,0);const sc=.8+Math.random()*1.6;mesh.scale.set(sc,sc,sc);shapes.push({mesh,rx:(Math.random()-.5)*.005,ry:(Math.random()-.5)*.005,fs:Math.random()*.3+.1,fa:Math.random()*.5+.2,iy:mesh.position.y});scene.add(mesh);}
let mx=0,my=0;document.addEventListener('mousemove',e=>{mx=(e.clientX/window.innerWidth-.5)*.5;my=(e.clientY/window.innerHeight-.5)*.5;});
let t=0;function animate(){requestAnimationFrame(animate);t+=.008;shapes.forEach(s=>{s.mesh.rotation.x+=s.rx;s.mesh.rotation.y+=s.ry;s.mesh.position.y=s.iy+Math.sin(t*s.fs)*s.fa;});camera.position.x+=(mx*3-camera.position.x)*.02;camera.position.y+=(-my*2-camera.position.y)*.02;renderer.render(scene,camera);}
animate();
window.addEventListener('resize',()=>{camera.aspect=window.innerWidth/window.innerHeight;camera.updateProjectionMatrix();renderer.setSize(window.innerWidth,window.innerHeight);});

// NAV SCROLL
window.addEventListener('scroll',()=>document.getElementById('navbar').classList.toggle('scrolled',scrollY>30));

// FADE IN
const fo=new IntersectionObserver(entries=>entries.forEach(e=>{if(e.isIntersecting)e.target.classList.add('vis');}),{threshold:.15});
document.querySelectorAll('.fade-in').forEach(el=>fo.observe(el));
</script>
</body>
</html>
